<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <appSettings>
    <!-- Database file name. Stored next to the executable. -->
    <add key="DatabaseFile" value="Customers.mdb" />
  </appSettings>
</configuration>
